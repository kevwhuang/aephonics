---
import IconArrowUpRight from '@components/IconArrowUpRight.astro';

interface Site {
    color: string;
    description: string;
    href: string;
    title: string;
}

const SITES: Site[] = [
    {
        color: 'var(--color-cyan)',
        description: 'Algorithms and data structures',
        href: 'https://algo.aephonics.com',
        title: 'Algo',
    },
    {
        color: 'var(--color-indigo)',
        description: 'Web engineering portfolio',
        href: 'https://dev.aephonics.com',
        title: 'Dev',
    },
    {
        color: 'var(--color-orange)',
        description: 'Producer catalog',
        href: 'https://music.aephonics.com',
        title: 'Music',
    },
    {
        color: 'var(--color-pink)',
        description: 'Interactive map',
        href: 'https://travel.aephonics.com',
        title: 'Travel',
    },
];
---

<section class="px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)] bg-zinc-950">
    <div class="grid grid-cols-1 max-w-7xl mx-auto gap-[clamp(1.5rem,calc(1rem+2.5vw),3rem)] md:grid-cols-2">
        {
            SITES.map(({ color, description, href, title }) => (
                <a
                    class="card active:scale-[0.99] focus-visible:-translate-y-1 hover:-translate-y-1 group overflow-hidden relative min-h-[clamp(6rem,calc(5.33rem+3.33vw),8rem)] p-[clamp(1.5rem,calc(0.67rem+4.17vw),4rem)] border border-white-10 bg-white-5"
                    aria-label={`Visit ${title}`}
                    data-scroll="up"
                    href={href}
                    style={`--accent: ${color}`}
                >
                    <div class="card__glow group-focus-visible:opacity-100 group-hover:opacity-100 absolute -inset-0.5 duration-300 opacity-0 transition-opacity" />
                    <div class="card__radial group-focus-visible:opacity-100 group-hover:opacity-100 absolute inset-0 duration-300 opacity-0 transition-opacity" />
                    <div class="card__line group-focus-visible:w-full group-hover:w-full absolute bottom-0 left-0 h-0.5 w-0 duration-300 ease-in-out transition-[width]" />
                    <div class="relative z-10">
                        <h2 class="card__title mb-[clamp(0.5rem,calc(0.33rem+0.83vw),1rem)] font-bold text-[clamp(1.5rem,calc(1.25rem+1.25vw),2.25rem)] tracking-tight text-white duration-300 transition-colors">
                            {title}
                        </h2>
                        <p class="group-focus-visible:text-zinc-300 group-hover:text-zinc-300 text-[clamp(0.875rem,calc(0.83rem+0.21vw),1rem)] text-zinc-400 duration-300 transition-colors">
                            {description}
                        </p>
                    </div>
                    <IconArrowUpRight />
                </a>
            ))
        }
    </div>
</section>

<style>
    .card {
        transition:
            background-color 0.3s cubic-bezier(0.4, 0, 0.2, 1),
            border-color 0.3s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1),
            transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .card:focus-visible,
    .card:hover {
        background-color: var(--color-white-5);
        border-color: color-mix(in srgb, var(--accent) 50%, transparent);
        box-shadow: 0 20px 40px -20px
            color-mix(in srgb, var(--accent) 30%, transparent);
    }

    .card:focus-visible .card__glow,
    .card:hover .card__glow {
        animation: card__glow 2s ease-in-out infinite;
    }

    .card:focus-visible .card__icon,
    .card:hover .card__icon {
        color: var(--accent);
        filter: drop-shadow(
            0 0 8px color-mix(in srgb, var(--accent) 50%, transparent)
        );
    }

    .card:focus-visible .card__title,
    .card:hover .card__title {
        color: var(--accent);
        text-shadow: 0 0 30px color-mix(in srgb, var(--accent) 50%, transparent);
    }

    .card__glow {
        background: linear-gradient(
            to bottom right,
            transparent,
            color-mix(in srgb, var(--accent) 10%, transparent),
            transparent
        );
    }

    .card__line {
        background: linear-gradient(to right, var(--accent), color-mix(in srgb, var(--accent) 60%, var(--color-white)));
    }

    .card__radial {
        background: radial-gradient(circle at 80% 20%, color-mix(in srgb, var(--accent) 15%, transparent) 0%, transparent 50%);
    }

    @keyframes card__glow {
        0%,
        100% {
            transform: translateX(-100%);
        }

        50% {
            transform: translateX(100%);
        }
    }
</style>
