---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-zinc-950">
    <div class="max-w-7xl mx-auto px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)]">
        <p class="text-center text-[clamp(0.75rem,calc(0.67rem+0.42vw),1rem)] text-zinc-500">
            &copy; {year} Aephonics. All rights reserved.
        </p>
    </div>
</footer>
