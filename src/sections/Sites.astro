---
import ArrowUpRightIcon from '@components/ArrowUpRightIcon.astro';

interface Site {
    color: string;
    description: string;
    href: string;
    title: string;
}

const sites: Site[] = [
    {
        color: 'rgb(var(--color-indigo))',
        description: 'Complexity tamed into elegant solutions',
        href: 'https://algo.aephonics.com',
        title: 'Algo',
    },
    {
        color: 'rgb(var(--color-cyan))',
        description: 'Building the systems that power tomorrow',
        href: 'https://dev.aephonics.com',
        title: 'Dev',
    },
    {
        color: 'rgb(var(--color-pink))',
        description: 'Frequencies shaped into feeling',
        href: 'https://music.aephonics.com',
        title: 'Music',
    },
    {
        color: 'rgb(var(--color-orange))',
        description: 'Worlds witnessed, moments preserved',
        href: 'https://travel.aephonics.com',
        title: 'Travel',
    },
];
---

<section class="px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)] bg-zinc-950">
    <div class="grid grid-cols-1 max-w-7xl mx-auto gap-[clamp(1.5rem,calc(0.83rem+3.33vw),3rem)] md:grid-cols-2">
        {
            sites.map(({ color, description, href, title }) => (
                <a
                    class="card group relative min-h-32 p-[clamp(1.5rem,calc(0.67rem+4.17vw),4rem)] border border-white/10 bg-white/[0.03] overflow-hidden hover:-translate-y-1 active:scale-[0.99]"
                    aria-label={`Visit ${title}`}
                    data-scroll="up"
                    href={href}
                    style={`--accent: ${color}`}
                >
                    <div class="card__glow absolute -inset-0.5 opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
                    <div class="card__radial absolute inset-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
                    <div class="card__line absolute bottom-0 left-0 h-0.5 w-0 transition-all duration-300 ease-out group-hover:w-full" />
                    <div class="relative z-10">
                        <h2 class="card__title mb-[clamp(0.5rem,calc(0.33rem+0.83vw),1rem)] font-bold text-4xl tracking-tight text-white transition-colors duration-300">
                            {title}
                        </h2>
                        <p class="text-base text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300">
                            {description}
                        </p>
                    </div>
                    <ArrowUpRightIcon />
                </a>
            ))
        }
    </div>
</section>

<style>
    .card {
        transition:
            background-color 0.3s cubic-bezier(0.4, 0, 0.2, 1),
            border-color 0.3s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1),
            transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .card__glow {
        background: linear-gradient(
            to bottom right,
            transparent,
            color-mix(in srgb, var(--accent) 10%, transparent),
            transparent
        );
    }

    .card__line {
        background: linear-gradient(
            to right,
            var(--accent),
            color-mix(in srgb, var(--accent) 60%, white)
        );
    }

    .card__radial {
        background: radial-gradient(
            circle at 80% 20%,
            color-mix(in srgb, var(--accent) 15%, transparent) 0%,
            transparent 50%
        );
    }

    .card:hover {
        background-color: rgba(var(--rgb-white), 0.06);
        border-color: color-mix(in srgb, var(--accent) 50%, transparent);
        box-shadow: 0 20px 40px -20px
            color-mix(in srgb, var(--accent) 30%, transparent);
    }

    .card:hover .card__glow {
        animation: card__glow 2s ease-in-out infinite;
    }

    .card:hover .card__icon {
        color: var(--accent);
        filter: drop-shadow(
            0 0 8px color-mix(in srgb, var(--accent) 50%, transparent)
        );
    }

    .card:hover .card__title {
        color: var(--accent);
        text-shadow: 0 0 30px color-mix(in srgb, var(--accent) 50%, transparent);
    }

    @keyframes card__glow {
        0%,
        100% {
            transform: translateX(-100%);
        }

        50% {
            transform: translateX(100%);
        }
    }
</style>
