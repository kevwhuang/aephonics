---
import IconArrowDown from '@components/IconArrowDown.astro';
---

<section
    class="hero flex items-center justify-center overflow-hidden relative min-h-screen"
>
    <canvas class="hero__grid absolute inset-0" aria-hidden="true"></canvas>
    <canvas class="hero__pulses absolute inset-0" aria-hidden="true"></canvas>
    <div
        class="hero__content relative z-10 max-w-7xl px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] text-center select-none"
    >
        <h1
            class="hero__title mb-[clamp(1rem,calc(0.33rem+3.33vw),3rem)] font-extralight leading-none text-[clamp(2.5rem,calc(-0.67rem+15.83vw),12rem)] tracking-wide"
            aria-label="aephonics"
        >
        </h1>
        <p
            class="hero__tagline max-w-2xl mx-auto font-mono lowercase text-[clamp(0.875rem,calc(0.58rem+1.46vw),1.75rem)] tracking-[clamp(0.25rem,calc(0.17rem+0.42vw),0.5rem)] opacity-0"
        >
            <span class="hero__tag hero__tag--atx">atx</span>
            <span class="text-zinc-600">/</span>
            <span class="hero__tag hero__tag--syntax">syntax</span>
            <span class="text-zinc-600">/</span>
            <span class="hero__tag hero__tag--wavs">wavs</span>
        </p>
    </div>
    <div
        class="hero__arrow absolute bottom-[clamp(2rem,calc(1.67rem+1.67vw),3rem)] left-1/2 p-2 opacity-0 -translate-x-1/2 animate-bounce transition-opacity duration-500"
    >
        <IconArrowDown />
    </div>
</section>

<style>
    .hero__cursor {
        animation: hero__blink 0.5s steps(1) infinite;
        -webkit-text-fill-color: var(--color-white);
    }

    .hero__grid,
    .hero__pulses {
        animation: hero__fade-in 2s ease-out forwards;
    }

    .hero__tag--atx {
        color: var(--color-pink-70);
        text-shadow: 0 0 15px var(--color-pink-30);
    }

    .hero__tag--syntax {
        color: var(--color-indigo-70);
        text-shadow: 0 0 15px var(--color-indigo-30);
    }

    .hero__tag--wavs {
        color: var(--color-orange-70);
        text-shadow: 0 0 15px var(--color-orange-30);
    }

    .hero__title {
        background: linear-gradient(
            90deg,
            var(--color-white-75) 0%,
            var(--color-white-75) 40%,
            var(--color-white) 50%,
            var(--color-white-75) 60%,
            var(--color-white-75) 100%
        );
        background-clip: text;
        background-size: 250% 100%;
        filter: drop-shadow(0 0 40px var(--color-white-10));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    @keyframes hero__blink {
        50% {
            opacity: 0;
        }
    }

    @keyframes hero__fade-in {
        0% {
            opacity: 0;
        }

        100% {
            opacity: 0.6;
        }
    }

    @keyframes hero__title {
        0%,
        100% {
            background-position: 150% 50%;
        }

        50% {
            background-position: -50% 50%;
        }
    }
</style>

<script>
    interface Point {
        x: number;
        y: number;
    }

    interface Pulse extends Point {
        direction: Direction;
        trail: Point[];
    }

    const ARROW_SHOW_DELAY = 2_000;
    const CANVAS_OPACITY = '0.6';
    const EDGE_COUNT = 4;
    const GRID_DRAW_INTERVAL = 30;
    const GRID_LINE_WIDTH = 1;
    const GRID_SIZE = 100;
    const MAX_PULSES = 5;
    const OFFSCREEN_MARGIN = 50;
    const PULSE_HEAD_RADIUS = 3;
    const PULSE_SHADOW_BLUR = 4;
    const PULSE_SPAWN_INTERVAL = 800;
    const PULSE_SPEED = 3;
    const PULSE_START_DELAY = 800;
    const SCROLL_THRESHOLD = 50;
    const SEQUENCE_START_DELAY = 2_200;
    const STRAIGHT_PROBABILITY = 0.92;
    const TAGLINE_FADE_DELAY = 800;
    const TITLE_INITIAL_BLUR = 8;
    const TITLE_SHIMMER_DELAY = 1_000;
    const TITLE_SHIMMER_DURATION = 10;
    const TITLE_TEXT = 'AEPHONICS';
    const TRAIL_ALPHA = 0.15;
    const TRAIL_LENGTH = 12;
    const TRAIL_RADIUS_MAX = 2;
    const TRAIL_RADIUS_MIN = 1;
    const TURN_BIAS = 0.5;
    const TWO_PI = Math.PI * 2;
    const TYPING_INTERVAL = 100;
    const TYPING_START_DELAY = 500;

    let animationFrameId = 0;
    let arrowVisible = false;
    let cyan = '';
    let cyan15 = '';
    let cyan30 = '';
    let cyan35 = '';
    let gridIntervalId = 0;
    let resizeHandler: (() => void) | null = null;
    let scrollHandler: (() => void) | null = null;
    let spawnIntervalId = 0;
    let startPulsesCallback: (() => void) | null = null;

    function cleanup() {
        cancelAnimationFrame(animationFrameId);
        clearInterval(gridIntervalId);
        clearInterval(spawnIntervalId);

        if (resizeHandler) {
            window.removeEventListener('resize', resizeHandler);
            resizeHandler = null;
        }

        if (scrollHandler) {
            window.removeEventListener('scroll', scrollHandler);
            scrollHandler = null;
        }
    }

    function drawLine(
        ctx: CanvasRenderingContext2D,
        x1: number,
        y1: number,
        x2: number,
        y2: number,
    ) {
        ctx.beginPath();
        ctx.moveTo(x1, y1);
        ctx.lineTo(x2, y2);
        ctx.stroke();
    }

    function hexAlpha(hex: string, alpha: number) {
        return hex + Math.round(alpha * 255).toString(16).padStart(2, '0');
    }

    function init() {
        const styles = getComputedStyle(document.documentElement);

        cleanup();
        arrowVisible = false;
        cyan = styles.getPropertyValue('--color-cyan').trim();
        startPulsesCallback = null;

        cyan15 = hexAlpha(cyan, 0.15);
        cyan30 = hexAlpha(cyan, 0.3);
        cyan35 = hexAlpha(cyan, 0.35);

        initGrid();
        initScrollArrow();
        initTypewriter();
    }

    function initGrid() {
        const gridCanvas = document.querySelector<HTMLCanvasElement>('.hero__grid');
        const pulseCanvas = document.querySelector<HTMLCanvasElement>('.hero__pulses');
        const section = document.querySelector<HTMLElement>('.hero');

        if (!gridCanvas || !pulseCanvas || !section) return;

        const gridCtx = gridCanvas.getContext('2d');
        const pulseCtx = pulseCanvas.getContext('2d');
        const pulses: Pulse[] = [];

        if (!gridCtx || !pulseCtx) return;

        let gridComplete = false;
        let horizontalLines = 0;
        let isInitialResize = true;
        let maxHorizontalLines = 0;
        let maxVerticalLines = 0;
        let verticalLines = 0;

        function animatePulses() {
            pulseCtx!.clearRect(0, 0, pulseCanvas!.width, pulseCanvas!.height);

            for (let i = pulses.length - 1; i >= 0; i--) {
                const pulse = pulses[i];

                pulse.trail.unshift({ x: pulse.x, y: pulse.y });

                if (pulse.trail.length > TRAIL_LENGTH) pulse.trail.pop();

                switch (pulse.direction) {
                    case 'down':
                        pulse.y += PULSE_SPEED;
                        break;
                    case 'left':
                        pulse.x -= PULSE_SPEED;
                        break;
                    case 'right':
                        pulse.x += PULSE_SPEED;
                        break;
                    case 'up':
                        pulse.y -= PULSE_SPEED;
                }

                const isHorizontal = pulse.direction === 'left' || pulse.direction === 'right';

                const position = isHorizontal ? pulse.x : pulse.y;

                const shouldTurn = Math.abs(position % GRID_SIZE) < PULSE_SPEED
                    && Math.random() > STRAIGHT_PROBABILITY;

                if (shouldTurn) {
                    if (isHorizontal) {
                        pulse.direction = Math.random() > TURN_BIAS ? 'down' : 'up';
                    } else {
                        pulse.direction = Math.random() > TURN_BIAS ? 'left' : 'right';
                    }
                }

                for (let j = 0; j < pulse.trail.length; j++) {
                    const alpha = (1 - j / TRAIL_LENGTH) * TRAIL_ALPHA;
                    const radius = (1 - j / TRAIL_LENGTH) * TRAIL_RADIUS_MAX + TRAIL_RADIUS_MIN;

                    pulseCtx!.fillStyle = hexAlpha(cyan, alpha);
                    pulseCtx!.beginPath();
                    pulseCtx!.arc(pulse.trail[j].x, pulse.trail[j].y, radius, 0, TWO_PI);
                    pulseCtx!.fill();
                }

                pulseCtx!.fillStyle = cyan35;
                pulseCtx!.shadowBlur = PULSE_SHADOW_BLUR;
                pulseCtx!.shadowColor = cyan30;
                pulseCtx!.beginPath();
                pulseCtx!.arc(pulse.x, pulse.y, PULSE_HEAD_RADIUS, 0, TWO_PI);
                pulseCtx!.fill();
                pulseCtx!.shadowBlur = 0;

                const offscreen = pulse.x < -OFFSCREEN_MARGIN
                    || pulse.x > pulseCanvas!.width + OFFSCREEN_MARGIN
                    || pulse.y < -OFFSCREEN_MARGIN
                    || pulse.y > pulseCanvas!.height + OFFSCREEN_MARGIN;

                if (offscreen) pulses.splice(i, 1);
            }

            animationFrameId = requestAnimationFrame(animatePulses);
        }

        function handleResize() {
            const height = section!.offsetHeight;
            const width = section!.offsetWidth;

            gridCanvas!.height = height;
            gridCanvas!.width = width;
            pulseCanvas!.height = height;
            pulseCanvas!.width = width;
            maxHorizontalLines = Math.ceil(height / GRID_SIZE) + 1;
            maxVerticalLines = Math.ceil(width / GRID_SIZE) + 1;

            if (!isInitialResize) {
                const ctx = gridCtx!;
                const h = gridCanvas!.height;
                const w = gridCanvas!.width;

                gridCanvas!.style.animation = 'none';
                gridCanvas!.style.opacity = CANVAS_OPACITY;
                gridComplete = true;
                pulseCanvas!.style.animation = 'none';
                pulseCanvas!.style.opacity = CANVAS_OPACITY;
                ctx.clearRect(0, 0, w, h);
                ctx.lineWidth = GRID_LINE_WIDTH;
                ctx.strokeStyle = cyan15;

                for (let y = 0; y <= h; y += GRID_SIZE) {
                    drawLine(ctx, 0, y, w, y);
                }

                for (let x = 0; x <= w; x += GRID_SIZE) {
                    drawLine(ctx, x, 0, x, h);
                }
            }

            isInitialResize = false;
        }

        function randomGridX() {
            return Math.floor(Math.random() * maxVerticalLines) * GRID_SIZE;
        }

        function randomGridY() {
            return Math.floor(Math.random() * maxHorizontalLines) * GRID_SIZE;
        }

        function spawnPulse() {
            if (pulses.length >= MAX_PULSES) return;

            const edge = Math.floor(Math.random() * EDGE_COUNT);

            let direction: Direction;
            let x: number;
            let y: number;

            switch (edge) {
                case 0:
                    direction = 'right';
                    x = 0;
                    y = randomGridY();
                    break;
                case 1:
                    direction = 'down';
                    x = randomGridX();
                    y = 0;
                    break;
                case 2:
                    direction = 'left';
                    x = gridCanvas!.width;
                    y = randomGridY();
                    break;
                default:
                    direction = 'up';
                    x = randomGridX();
                    y = gridCanvas!.height;
            }

            pulses.push({ direction, trail: [], x, y });
        }

        function startPulses() {
            animatePulses();
            spawnIntervalId = window.setInterval(spawnPulse, PULSE_SPAWN_INTERVAL);
            spawnPulse();
        }

        handleResize();
        resizeHandler = handleResize;
        startPulsesCallback = startPulses;
        window.addEventListener('resize', handleResize);

        gridIntervalId = window.setInterval(() => {
            if (gridComplete) {
                clearInterval(gridIntervalId);
                gridCanvas!.style.animation = 'none';
                gridCanvas!.style.opacity = CANVAS_OPACITY;
                pulseCanvas!.style.animation = 'none';
                pulseCanvas!.style.opacity = CANVAS_OPACITY;

                return;
            }

            const ctx = gridCtx!;
            const h = gridCanvas!.height;
            const w = gridCanvas!.width;

            ctx.lineWidth = GRID_LINE_WIDTH;
            ctx.strokeStyle = cyan15;

            if (horizontalLines < maxHorizontalLines) {
                drawLine(ctx, 0, horizontalLines * GRID_SIZE, w, horizontalLines * GRID_SIZE);
                horizontalLines++;
            } else if (verticalLines < maxVerticalLines) {
                drawLine(ctx, verticalLines * GRID_SIZE, 0, verticalLines * GRID_SIZE, h);
                verticalLines++;
            } else {
                gridComplete = true;
            }
        }, GRID_DRAW_INTERVAL);
    }

    function initScrollArrow() {
        const arrow = document.querySelector('.hero__arrow');

        if (!arrow) return;

        function handleScroll() {
            if (!arrowVisible) return;

            (arrow as HTMLElement).style.opacity = window.scrollY > SCROLL_THRESHOLD ? '0' : '1';
        }

        scrollHandler = handleScroll;
        window.addEventListener('scroll', handleScroll, { passive: true });
    }

    function initTypewriter() {
        const tagline = document.querySelector('.hero__tagline') as HTMLElement | null;
        const title = document.querySelector('.hero__title') as HTMLElement | null;

        if (!title || title.dataset.typed) return;

        let charIndex = 0;
        let cursorSpan: HTMLSpanElement | null = null;
        let textSpan: HTMLSpanElement | null = null;

        function typeNextChar() {
            if (charIndex < TITLE_TEXT.length) {
                if (textSpan) textSpan.textContent = TITLE_TEXT.slice(0, charIndex + 1);

                charIndex++;
                setTimeout(typeNextChar, TYPING_INTERVAL);
            } else {
                if (cursorSpan) cursorSpan.remove();

                title!.style.filter = 'blur(0px)';

                setTimeout(() => {
                    if (tagline) {
                        tagline.style.opacity = '1';
                        tagline.style.transition = 'opacity 1s ease-out';
                    }
                }, TAGLINE_FADE_DELAY);

                setTimeout(() => {
                    title!.style.animation = `hero__title ${TITLE_SHIMMER_DURATION}s ease-in-out infinite`;
                }, TITLE_SHIMMER_DELAY);

                setTimeout(() => {
                    const arrow = document.querySelector('.hero__arrow') as HTMLElement | null;

                    if (arrow) arrow.style.opacity = '1';

                    arrowVisible = true;
                }, ARROW_SHOW_DELAY);

                setTimeout(() => {
                    startPulsesCallback?.();
                }, ARROW_SHOW_DELAY + PULSE_START_DELAY);
            }
        }

        title.dataset.typed = 'true';
        title.style.filter = `blur(${TITLE_INITIAL_BLUR}px)`;
        title.style.transition = 'filter 1.5s ease-out';

        setTimeout(() => {
            title!.textContent = '';
            cursorSpan = document.createElement('span');
            cursorSpan.className = 'hero__cursor';
            cursorSpan.textContent = '|';
            textSpan = document.createElement('span');
            textSpan.className = 'hero__text';
            title!.append(textSpan, cursorSpan);
            setTimeout(typeNextChar, TYPING_START_DELAY);
        }, SEQUENCE_START_DELAY);
    }

    document.addEventListener('astro:page-load', init);
</script>
