---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-zinc-950">
    <div class="mx-auto max-w-7xl px-[clamp(1rem,calc(0.5rem+2.5vw),2.5rem)] py-[clamp(3rem,calc(1.33rem+8.33vw),8rem)]">
        <p class="text-center text-sm text-zinc-500">
            &copy; {year} Aephonics. All rights reserved.
        </p>
    </div>
</footer>
