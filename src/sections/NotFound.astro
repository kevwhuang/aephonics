<section
    class="not-found flex min-h-screen items-center justify-center bg-black px-6"
>
    <div class="not-found__content select-none text-center">
        <h1
            class="not-found__title mb-12 font-bold text-8xl tracking-widest sm:text-9xl md:text-[12rem] lg:text-[14rem]"
        >
            404
        </h1>
        <a
            class="not-found__link inline-block border border-white/20 px-8 py-4 font-mono text-sm lowercase tracking-[0.2em] text-white/70 transition-all duration-300"
            href="/"
        >
            return
        </a>
    </div>
</section>

<style>
    .not-found__link:hover {
        background-color: rgba(255, 255, 255, 0.05);
        border-color: rgba(6, 182, 212, 0.5);
        color: rgba(6, 182, 212, 0.9);
        text-shadow: 0 0 20px rgba(6, 182, 212, 0.3);
    }

    .not-found__title {
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background: linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.9) 0%,
            rgba(255, 255, 255, 0.4) 100%
        );
        background-clip: text;
        filter: drop-shadow(0 0 60px rgba(6, 182, 212, 0.15));
    }
</style>
